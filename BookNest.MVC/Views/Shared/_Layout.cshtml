@using Microsoft.AspNetCore.Identity
@using BookNest.Core.Entities
@inject SignInManager<AppUser> SignInManager
@inject UserManager<AppUser> UserManager


<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BookNest</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
    <link href="~/admin/css/site.css" rel="stylesheet" asp-append-version="true" />
</head>
<body>

    <div class="container">
        <nav class="navbar">
            <a asp-controller="Home" asp-action="Index" class="logo">booknest</a>

            <div class="search-container">
                <form asp-controller="Book" asp-action="Index" method="get">
                    <input type="text" name="search" placeholder="Search book name, author,...">
                </form>
            </div>

            <div class="nav-links">
                <a asp-controller="Home" asp-action="Index" class="active"><span class="nav-icons">🏠</span> Home</a>
                @if (SignInManager.IsSignedIn(User))
                {
                    <a asp-controller="Shelf" asp-action="Index"><span class="nav-icons">📚</span> Book Shelf</a>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" title="Sign in to access your shelf"><span class="nav-icons">📚</span> Book Shelf</a>
                }
                <a asp-controller="Book" asp-action="Index" class="active"><span class="nav-icons">🧭</span> Browse</a>
            </div>

            <div class="profile-section" style="display: flex; gap: 15px; align-items: center;">
                @if (SignInManager.IsSignedIn(User))
                {
                    var currentUser = await UserManager.GetUserAsync(User);
                    var fullName = currentUser?.FullName ?? "User";
                    var initials = string.Join("", fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(n => n[0])).ToUpper();
                    var isAdmin = await UserManager.IsInRoleAsync(currentUser, "Admin");

                    @if (isAdmin)
                    {
                        <span style="background: #D93838; color: white; padding: 4px 12px; border-radius: 20px; font-size: 11px; font-weight: 700; text-transform: uppercase;">
                            Admin
                        </span>
                        <a asp-area="AdminPanel" asp-controller="Dashboard" asp-action="Index" style="padding: 8px 15px; border-radius: 20px; font-size: 13px; font-weight: 600; text-decoration: none; background: var(--primary-gold); color: white;">
                            Dashboard →
                        </a>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Profile" style="display: flex; align-items: center; justify-content: center; width: 35px; height: 35px; border-radius: 50%; background: var(--primary-gold); color: white; font-weight: bold; text-decoration: none; font-size: 14px;" title="@fullName">
                            @if (!string.IsNullOrEmpty(currentUser?.ProfileImageUrl))
                            {
                                <img src="~/uploads/profiles/@currentUser.ProfileImageUrl" alt="@fullName" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover;">
                            }
                            else
                            {
                                @initials
                            }
                        </a>
                    }

                    <a asp-controller="Account" asp-action="Logout" style="padding: 6px 15px; border-radius: 20px; font-size: 13px; font-weight: 500; text-decoration: none; border: 1px solid var(--text-dark); color: var(--text-dark);">Logout</a>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" style="font-weight: 600; font-size: 14px; color: var(--text-dark); text-decoration: none;">Sign In</a>
                    <a asp-controller="Account" asp-action="Register" style="background: #5C4B33; color: white; padding: 8px 18px; border-radius: 20px; font-size: 14px; text-decoration: none;">Sign Up</a>
                }
            </div>
        </nav>

        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer style="background-color: #2C2620; color: #EAE4D4; padding: 60px 0 30px 0; font-family: sans-serif; border-top: 3px solid #9D7B48;">
        <div style="max-width: 1200px; margin: 0 auto; padding: 0 20px;">

            <div style="display: flex; flex-wrap: wrap; justify-content: space-between; gap: 40px; margin-bottom: 40px;">

                <div style="flex: 1; min-width: 250px;">
                    <h3 style="font-family: var(--font-serif, serif); font-size: 28px; color: #FFF; margin-bottom: 15px; margin-top: 0;">booknest.</h3>
                    <p style="color: #A39683; font-size: 14px; line-height: 1.6; max-width: 300px; margin: 0;">
                        Your personal bookshelf. Discover new books, track your reading journey, and share your thoughts with the community.
                    </p>
                </div>

                <div style="flex: 1; min-width: 200px;">
                    <h5 style="color: #FFF; font-size: 14px; margin-bottom: 20px; font-weight: 700; letter-spacing: 1.5px;">QUICK LINKS</h5>
                    <ul style="list-style: none; padding: 0; margin: 0; line-height: 2.2;">
                        <li><a href="/Home/Index" style="color: #A39683; text-decoration: none; font-size: 14px; transition: 0.3s;" onmouseover="this.style.color='#FFF'" onmouseout="this.style.color='#A39683'">Home</a></li>
                        <li><a href="/Book/Index" style="color: #A39683; text-decoration: none; font-size: 14px; transition: 0.3s;" onmouseover="this.style.color='#FFF'" onmouseout="this.style.color='#A39683'">Browse Books</a></li>
                        <li><a href="/Shelf/Index" style="color: #A39683; text-decoration: none; font-size: 14px; transition: 0.3s;" onmouseover="this.style.color='#FFF'" onmouseout="this.style.color='#A39683'">My Book Shelf</a></li>
                    </ul>
                </div>

                <div style="flex: 1; min-width: 250px;">
                    <h5 style="color: #FFF; font-size: 14px; margin-bottom: 20px; font-weight: 700; letter-spacing: 1.5px;">CONNECT & CODE</h5>
                    <p style="color: #A39683; font-size: 14px; margin-bottom: 15px; line-height: 1.6;">
                        Explore the open-source code and connect with the developer:
                    </p>
                    <div style="display: flex; gap: 20px; align-items: center;">

                        <a href="https://github.com/aqshinn" target="_blank" style="color: #EAE4D4; transition: 0.3s;" onmouseover="this.style.color='#9D7B48'" onmouseout="this.style.color='#EAE4D4'">
                            <svg height="26" width="26" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z" />
                            </svg>
                        </a>

                        <a href="https://linkedin.com/in/senin-username" target="_blank" style="color: #EAE4D4; transition: 0.3s;" onmouseover="this.style.color='#9D7B48'" onmouseout="this.style.color='#EAE4D4'">
                            <svg height="26" width="26" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854V1.146zm4.943 12.248V6.169H2.542v7.225h2.401zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248-.822 0-1.359.54-1.359 1.248 0 .694.521 1.248 1.327 1.248h.016zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016a5.54 5.54 0 0 1 .016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225h2.4z" />
                            </svg>
                        </a>
                    </div>
                </div>

            </div>

            <div style="border-top: 1px solid rgba(234, 228, 212, 0.1); padding-top: 25px; display: flex; justify-content: space-between; flex-wrap: wrap; gap: 10px;">
                <p style="color: #A39683; font-size: 13px; margin: 0;">
                    &copy; @DateTime.Now.Year BookNest. All rights reserved.
                </p>
                <p style="color: #A39683; font-size: 13px; margin: 0;">
                    Designed & Developed by <strong>Aqshin</strong>
                </p>
            </div>

        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <script>
        toastr.options = {
            "closeButton": true,
            "progressBar": true,
            "positionClass": "toast-top-right",
            "timeOut": "3000"
        };
    </script>

    @if (TempData["Success"] != null)
    {
        <script>
            toastr.success('@TempData["Success"]');
        </script>
    }

    @if (TempData["Error"] != null)
    {
        <script>
            toastr.error('@TempData["Error"]');
        </script>
    }

    @if (TempData["Warning"] != null)
    {
        <script>
            toastr.warning('@TempData["Warning"]');
        </script>
    }

    @if (TempData["Info"] != null)
    {
        <script>
            toastr.info('@TempData["Info"]');
        </script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>