@model BookNest.MVC.ViewModels.ErrorViewModel

@{
    ViewData["Title"] = "An Error Occurred";
}

<div style="height: 70vh; display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; color: var(--text-dark); font-family: sans-serif; padding: 20px;">

    <h1 style="font-size: 150px; font-family: var(--font-serif, serif); color: #9D7B48; margin: 0; line-height: 1; text-shadow: 4px 4px 0px rgba(157, 123, 72, 0.2);">
        @(Model.StatusCode?.ToString() ?? "Oops!")
    </h1>

    <h3 style="font-size: 28px; margin-bottom: 15px; color: #2C2620;">Page not found!</h3>

    <p style="color: #A39683; font-size: 16px; max-width: 450px; line-height: 1.6; margin-bottom: 40px;">
        @Model.ErrorMessage
    </p>

    <a href="/Home/Index" style="background-color: #2C2620; color: #EAE4D4; padding: 14px 35px; border-radius: 30px; text-decoration: none; font-weight: 600; letter-spacing: 1px; transition: all 0.3s ease; box-shadow: 0 4px 15px rgba(0,0,0,0.1);" onmouseover="this.style.backgroundColor='#9D7B48'; this.style.transform='translateY(-3px)';" onmouseout="this.style.backgroundColor='#2C2620'; this.style.transform='translateY(0)';">
        Return to Homepage
    </a>
</div>